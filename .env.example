# ci-workflows env vars
# Copy this file to .env (gitignored) and fill in real values.
# Required for: sync, provision_secrets, drift modules.

# Codeberg Personal Access Token (your account)
# Scopes needed: repo (read/write), write:repository
# Source: https://codeberg.org/user/settings/applications
CODEBERG_TOKEN=

# Optional — git commit ref recorded in each caller's .ci-workflows-version.
# Defaults to "HEAD" when unset.
# CI_WORKFLOWS_COMMIT=HEAD

# ---------------------------------------------------------------------------
# Provisioned secrets (read by `python -m ci_workflows.provision_secrets`)
# ---------------------------------------------------------------------------
# These are NOT loaded from this file — they live in a separate secrets file
# outside the repo so they are never near a `git add` accident:
#
#   ~/.ci-secrets.env
#
# That file must contain ONLY allowlisted keys (currently TELEGRAM_CI_TOKEN).
# The allowlist is enforced in src/ci_workflows/provision_secrets.py
# (ALLOWED_SECRETS frozenset) — adding any other key raises UnknownSecretError.
#
# Example contents of ~/.ci-secrets.env:
#   TELEGRAM_CI_TOKEN=<bot-token-from-BotFather>
#
# Override the path with `--env <path>` if needed.
